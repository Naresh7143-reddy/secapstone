# Server
PORT=5000
NODE_ENV=development

# CORS — your frontend origin
FRONTEND_URL=http://localhost:3000

# Firebase
FIREBASE_PROJECT_ID=your_project_id
# Recommended on Render: paste the FULL service-account JSON (one line) here.
# Locally you can instead drop firebase-admin-config.json in the project root.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Supabase
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
# Use the service_role key on the server so RLS doesn't block inserts.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Judge0 (RapidAPI)
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your_rapidapi_key
